---
const { education } = Astro.props;
---

<section class="section">
  <h2>Education</h2>

  {education.map((item) => (
    <article class="compact-item">
      <h3>{item.degree}: {item.field}</h3>
      <p>
        {item.institution} — {item.location}, {item.completed}
      </p>
    </article>
  ))}
</section>