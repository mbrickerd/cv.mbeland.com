---
import type { ExperienceEntry, ProjectEntry } from "../content.config";

interface Props {
  experience: ExperienceEntry[];
  projects: ProjectEntry[];
}

const { experience, projects } = Astro.props;

const projectsByExperience = new Map<string, ProjectEntry[]>();
for (const project of projects) {
  const existing = projectsByExperience.get(project.experienceId) ?? [];
  projectsByExperience.set(project.experienceId, [...existing, project]);
}
---

<section class="section">
  <h2>Work History</h2>

  <div class="timeline">
    {
      experience.map((item) => (
        <article class="experience-item">
          <div class="period">{item.period}</div>

          <div class="experience-content">
            <h3>{item.role}</h3>
            <p class="company">
              <strong>{item.company}</strong> — {item.location}
            </p>

            <ul>
              {(projectsByExperience.get(item.id) ?? []).map((project) => (
                <li>
                  <strong>{project.title}</strong> — {project.printSummary}
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))
    }
  </div>
</section>
