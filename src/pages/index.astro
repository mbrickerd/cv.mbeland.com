---
import { getCollection } from "astro:content";

import { cv } from "../data/cv";
import CvLayout from "../layouts/CvLayout.astro";
import Hero from "../components/Hero.astro";
import Summary from "../components/Summary.astro";
import Skills from "../components/Skills.astro";
import ExperienceTimeline from "../components/ExperienceTimeline.astro";
import Education from "../components/Education.astro";
import Certifications from "../components/Certifications.astro";
import Languages from "../components/Languages.astro";
import Hobbies from "../components/Hobbies.astro";
import InteractiveCV from "../components/InteractiveCV";

function parseStartDate(period: string): Date {
  const [monthStr, yearStr] = period.split(" to ")[0].split("/");
  return new Date(parseInt(yearStr), parseInt(monthStr) - 1, 1);
}

const experienceEntries = await getCollection("experience");
const experience = experienceEntries
  .sort((a, b) => parseStartDate(b.data.period).getTime() - parseStartDate(a.data.period).getTime())
  .map((entry) => ({ id: entry.id, ...entry.data }));

const projectEntries = await getCollection("projects");
const projects = projectEntries.map((entry) => ({
  id: entry.id,
  ...entry.data,
}));
---

<CvLayout title={`${cv.name} | ${cv.title}`}>
  <main class="cv-page">
    <Hero cv={cv} />
    <Summary summary={cv.summary} />

    <section class="online-only">
      <InteractiveCV client:load skillGroups={cv.skillGroups} experience={experience} projects={projects} />
    </section>

    <section class="print-only">
      <Skills skillGroups={cv.skillGroups} />
      <ExperienceTimeline experience={experience} projects={projects} />
    </section>

    <Education education={cv.education} />
    <Certifications certifications={cv.certifications} />
    <Languages languages={cv.languages} />
    <Hobbies hobbies={cv.hobbies} />
  </main>
</CvLayout>
